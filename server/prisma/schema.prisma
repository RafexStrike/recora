// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Better Auth Models - Required for authentication
model user {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          String   @default("USER")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  accounts account[]
  sessions session[]
  // projects      project[]
  // animationJobs animationJob[]
  // donations     donation[]
}

model account {
  id                String   @id @default(cuid())
  accountId         String
  providerId        String
  userId            String
  type              String?
  provider          String?
  providerAccountId String?
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerAccountId])
  @@index([userId])
}

model session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  // Relations
  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

model studio {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recording_sessions recording_session[]
}

model recording_session {
  id        String   @id @default(cuid())
  studioId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio studio            @relation(fields: [studioId], references: [id], onDelete: Cascade)
  tracks recording_track[]
}

model recording_track {
  id                 String   @id @default(cuid())
  recordingSessionId String
  userId             String?
  participantId      String?  // LiveKit participant identity
  displayName        String?  // Display name (for guest participants)
  type               String   @default("video") // e.g. "video", "audio", "screen"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  recording_session recording_session @relation(fields: [recordingSessionId], references: [id], onDelete: Cascade)
  chunks            upload_chunk[]
}

model upload_chunk {
  id         String   @id @default(cuid())
  trackId    String
  chunkIndex Int
  blobUrl    String
  createdAt  DateTime @default(now())

  track recording_track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([trackId, chunkIndex])
}
